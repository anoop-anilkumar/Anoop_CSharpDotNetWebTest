@model AnoopUserRegistrationTest.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<section class="auth-shell">
    <div class="row g-4 justify-content-center">
        <div class="col-xl-7 col-lg-5">
            <div class="auth-card">
                <div class="section-heading">
                    <span class="section-kicker">Account security</span>
                    <h1>Change your password</h1>
                    <p>Confirm your current password, then choose a new one to keep your account secure.</p>
                </div>

                <form asp-action="ChangePassword" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary" role="alert"></div>

                    <div class="mb-3">
                        <label class="form-label" for="CurrentPassword">Current password</label>
                        <input asp-for="CurrentPassword" id="CurrentPassword" class="form-control form-control-lg" placeholder="Enter your current password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="NewPassword">New password</label>
                        <div class="password-field">
                            <input asp-for="NewPassword" id="NewPassword" class="form-control form-control-lg" placeholder="Enter a new password" />
                            <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">Show</button>
                        </div>
                        <div class="form-text">Use at least 8 characters with uppercase, lowercase, number, and special character.</div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="ConfirmPassword">Confirm password</label>
                        <input asp-for="ConfirmPassword" id="ConfirmPassword" class="form-control form-control-lg" placeholder="Re-enter the new password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Update password</button>
                    </div>
                </form>

                <p class="switch-link mt-4 mb-0">
                    Finished here?
                    <a asp-action="Welcome">Return to welcome page</a>
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
