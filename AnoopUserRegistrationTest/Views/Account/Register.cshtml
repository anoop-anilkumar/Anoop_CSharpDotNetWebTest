@model AnoopUserRegistrationTest.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <div class="row g-4 justify-content-center">
        <div class="col-lg-5">
            <div class="hero-panel h-100 d-flex flex-column justify-content-center">
                <span class="eyebrow">Anoop User Registration Test</span>
                <h1>Create your account</h1>
                <p class="hero-copy">
                    Register with validated details, secure password hashing, and duplicate-email protection.
                </p>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="auth-card">
                <div class="section-heading">
                    <span class="section-kicker">Registration</span>
                    <h2>Get started</h2>
                    <p>Fill in your details below to create a new user profile.</p>
                </div>

                <form asp-action="Register" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label" for="FirstName">First name</label>
                            <input asp-for="FirstName" id="FirstName" class="form-control form-control-lg" placeholder="John" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="LastName">Last name</label>
                            <input asp-for="LastName" id="LastName" class="form-control form-control-lg" placeholder="Doe" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="Email">Email</label>
                            <input asp-for="Email" id="Email" class="form-control form-control-lg" placeholder="john.doe@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="Password">Password</label>
                            <div class="password-field">
                                <input asp-for="Password" id="Password" class="form-control form-control-lg" placeholder="Minimum 8 characters" />
                                <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">Show</button>
                            </div>
                            <div class="form-text">Use at least 8 characters with uppercase, lowercase, number, and special character.</div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="ConfirmPassword">Confirm password</label>
                            <input asp-for="ConfirmPassword" id="ConfirmPassword" class="form-control form-control-lg" placeholder="Re-enter your password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Create account</button>
                    </div>
                </form>

                <p class="switch-link mt-4 mb-0">
                    Already registered?
                    <a asp-action="Login">Sign in here</a>
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
