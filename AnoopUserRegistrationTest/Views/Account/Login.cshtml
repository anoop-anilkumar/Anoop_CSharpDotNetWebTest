@model AnoopUserRegistrationTest.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
    <div class="row g-4 justify-content-center">
        <div class="col-xl-6 col-lg-4">
            <div class="auth-card">
                <div class="section-heading">
                    <span class="section-kicker">Login</span>
                    <h1>Welcome back</h1>
                    <p>Sign in using the email and password you registered with.</p>
                </div>

                @if (TempData["SuccessMessage"] is string successMessage)
                {
                    <div class="alert alert-success" role="alert">@successMessage</div>
                }

                @if (TempData["ErrorMessage"] is string errorMessage)
                {
                    <div class="alert alert-warning" role="alert">@errorMessage</div>
                }

                <form asp-action="Login" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary" role="alert"></div>

                    <div class="mb-3">
                        <label class="form-label" for="Email">Email</label>
                        <input asp-for="Email" id="Email" class="form-control form-control-lg" placeholder="john.doe@example.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="Password">Password</label>
                        <div class="password-field">
                            <input asp-for="Password" id="Password" class="form-control form-control-lg" placeholder="Enter your password" />
                            <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">Show</button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="form-check">
                        <input asp-for="RememberMe" id="RememberMe" class="form-check-input" />
                        <label class="form-check-label" for="RememberMe">Remember me</label>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Sign in</button>
                    </div>
                </form>

                <div class="helper-links">
                    <a asp-action="ForgotPassword">Forgot password?</a>
                </div>

                <p class="switch-link mt-4 mb-0">
                    Need an account?
                    <a asp-action="Register">Register now</a>
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
